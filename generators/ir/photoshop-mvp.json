{
  "host": "photoshop",
  "version": "0.1.0",
  "namespaces": [
    {
      "name": "app",
      "methods": [
        {"name": "getVersion", "returns": "str"},
        {"name": "getDocuments", "returns": "list[Document]"}
      ],
      "properties": [
        {"name": "documents", "type": "list[Document]", "source": "app.getDocuments"},
        {"name": "active_document", "type": "Document | None", "source": "document.getActive"},
        {"name": "active_layer", "type": "Layer | None", "source": "layer.getActive"},
        {"name": "active_layers", "type": "list[Layer]", "source": "document.getActiveLayers"},
        {"name": "selection", "type": "Selection | None", "source": "selection.get"},
        {"name": "channels", "type": "list[Channel]", "source": "channel.getChannels"}
      ]
    },
    {
      "name": "document",
      "methods": [
        {"name": "getActive", "returns": "Document | None"},
        {"name": "getById", "returns": "Document | None"},
        {"name": "getLayers", "returns": "list[Layer]"},
        {"name": "getActiveLayers", "returns": "list[Layer]"},
        {"name": "saveAs", "returns": "Any", "mutatesState": true, "requiresModalWhenMutating": true},
        {"name": "export", "returns": "Any", "mutatesState": true, "requiresModalWhenMutating": true}
      ]
    },
    {
      "name": "layer",
      "methods": [
        {"name": "getActive", "returns": "Layer | None"},
        {"name": "getChildren", "returns": "list[Layer]"}
      ]
    },
    {
      "name": "selection",
      "methods": [
        {"name": "get", "returns": "Selection | None"},
        {"name": "selectAll", "returns": "Selection", "mutatesState": true, "requiresModalWhenMutating": true},
        {"name": "deselect", "returns": "Selection", "mutatesState": true, "requiresModalWhenMutating": true},
        {"name": "inverse", "returns": "Selection", "mutatesState": true, "requiresModalWhenMutating": true},
        {"name": "selectRectangle", "returns": "Selection", "mutatesState": true, "requiresModalWhenMutating": true},
        {"name": "selectEllipse", "returns": "Selection", "mutatesState": true, "requiresModalWhenMutating": true},
        {"name": "selectPolygon", "returns": "Selection", "mutatesState": true, "requiresModalWhenMutating": true},
        {"name": "selectRow", "returns": "Selection", "mutatesState": true, "requiresModalWhenMutating": true},
        {"name": "selectColumn", "returns": "Selection", "mutatesState": true, "requiresModalWhenMutating": true},
        {"name": "expand", "returns": "Selection", "mutatesState": true, "requiresModalWhenMutating": true},
        {"name": "contract", "returns": "Selection", "mutatesState": true, "requiresModalWhenMutating": true},
        {"name": "feather", "returns": "Selection", "mutatesState": true, "requiresModalWhenMutating": true},
        {"name": "smooth", "returns": "Selection", "mutatesState": true, "requiresModalWhenMutating": true},
        {"name": "grow", "returns": "Selection", "mutatesState": true, "requiresModalWhenMutating": true},
        {"name": "translateBoundary", "returns": "Selection", "mutatesState": true, "requiresModalWhenMutating": true},
        {"name": "save", "returns": "Selection", "mutatesState": true, "requiresModalWhenMutating": true}
      ]
    },
    {
      "name": "channel",
      "methods": [
        {"name": "getChannels", "returns": "list[Channel]"},
        {"name": "getActiveChannels", "returns": "list[Channel]"},
        {"name": "getComponentChannels", "returns": "list[Channel]"},
        {"name": "getByName", "returns": "Channel | None"},
        {"name": "add", "returns": "Channel", "mutatesState": true, "requiresModalWhenMutating": true},
        {"name": "remove", "returns": "Channel", "mutatesState": true, "requiresModalWhenMutating": true}
      ]
    },
    {"name": "action", "methods": [{"name": "batchPlay", "returns": "Any", "mutatesState": true, "requiresModalWhenMutating": true}]},
    {
      "name": "raw",
      "methods": [
        {"name": "evalJs", "returns": "Any"},
        {"name": "getPath", "returns": "Any"},
        {"name": "callPath", "returns": "Any"}
      ]
    }
  ],
  "proxies": [
    {
      "name": "DocumentProxy",
      "properties": [
        {"name": "id", "type": "int | str | None"},
        {"name": "name", "type": "str | None"},
        {"name": "path", "type": "str | None"},
        {"name": "width", "type": "Any"},
        {"name": "height", "type": "Any"},
        {"name": "resolution", "type": "Any"},
        {"name": "saved", "type": "bool | None"},
        {"name": "mode", "type": "str | None"},
        {"name": "typename", "type": "str | None"},
        {"name": "layers", "type": "list[Layer]"},
        {"name": "active_layers", "type": "list[Layer]"},
        {"name": "selection", "type": "Selection"},
        {"name": "channels", "type": "list[Channel]"},
        {"name": "active_channels", "type": "list[Channel]"},
        {"name": "component_channels", "type": "list[Channel]"},
        {"name": "dom", "type": "PhotoshopDomProxy"}
      ],
      "methods": [
        {"name": "refresh", "returns": "Document"},
        {"name": "getChannel", "returns": "Channel | None"},
        {"name": "saveAs", "returns": "Any"},
        {"name": "export", "returns": "Any"}
      ]
    },
    {
      "name": "LayerProxy",
      "properties": [
        {"name": "id", "type": "int | str | None"},
        {"name": "name", "type": "str | None"},
        {"name": "kind", "type": "str | None"},
        {"name": "opacity", "type": "Any"},
        {"name": "visible", "type": "bool | None"},
        {"name": "typename", "type": "str | None"},
        {"name": "has_children", "type": "bool"},
        {"name": "layers", "type": "list[Layer]"}
      ],
      "methods": [{"name": "hide", "returns": "Any"}]
    },
    {
      "name": "SelectionProxy",
      "properties": [
        {"name": "bounds", "type": "dict[str, Any] | None"},
        {"name": "doc_id", "type": "int | str | None"},
        {"name": "solid", "type": "bool | None"},
        {"name": "typename", "type": "str | None"}
      ],
      "methods": [
        {"name": "refresh", "returns": "Selection"},
        {"name": "selectAll", "returns": "Selection"},
        {"name": "deselect", "returns": "Selection"},
        {"name": "inverse", "returns": "Selection"},
        {"name": "selectRectangle", "returns": "Selection"},
        {"name": "selectEllipse", "returns": "Selection"},
        {"name": "selectPolygon", "returns": "Selection"},
        {"name": "selectRow", "returns": "Selection"},
        {"name": "selectColumn", "returns": "Selection"},
        {"name": "expand", "returns": "Selection"},
        {"name": "contract", "returns": "Selection"},
        {"name": "feather", "returns": "Selection"},
        {"name": "smooth", "returns": "Selection"},
        {"name": "grow", "returns": "Selection"},
        {"name": "translateBoundary", "returns": "Selection"},
        {"name": "save", "returns": "Selection"}
      ]
    },
    {
      "name": "ChannelProxy",
      "properties": [
        {"name": "id", "type": "int | str | None"},
        {"name": "name", "type": "str | None"},
        {"name": "kind", "type": "str | None"},
        {"name": "opacity", "type": "Any"},
        {"name": "visible", "type": "bool | None"},
        {"name": "typename", "type": "str | None"}
      ],
      "methods": [{"name": "remove", "returns": "Channel"}]
    },
    {
      "name": "PhotoshopDomProxy",
      "methods": [
        {"name": "get", "returns": "Any"},
        {"name": "call", "returns": "Any"}
      ]
    }
  ]
}
